#!/usr/bin/zsh

alias gs="git status"
alias ga="git add"
alias gaa="git add ."
alias gcho="git checkout"
alias gchb="gcho -b"
alias gcha="gcho -- ."
alias gchm="gcho main"
alias gcm="git commit -m"
alias gca="git commit --amend"
alias gcan="git commit --amend --no-edit"
alias gfpl="git fetch origin && git pull"
alias glg="git log --graph --pretty=format:'%C(cyan)%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(magenta)<%an>%Creset' --abbrev-commit --date=relative"
alias gpu="git push origin -u"
alias gpf="git push origin -f"
alias gp="git push"
alias gr="git rebase"
alias grm="gr main"
alias gra="gr --abort"
alias grco="gr --continue"
alias gmm="git merge main"
alias gma="git merge --abort"
alias gmco="git merge --continue"

